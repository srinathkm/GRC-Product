{
  "name": "regulation-changes-dashboard",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "server": "cd server && npm run dev",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "build": "cd client && npm run build",
    "test": "cd server && npm test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "capture:readme-screenshot": "playwright screenshot --viewport-size=1440,900 --wait-for-timeout=5000 http://127.0.0.1:5173/ docs/images/readme-product-hero.png",
    "start": "cd server && npm start",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:package": "tar --exclude='node_modules' --exclude='client/node_modules' --exclude='server/node_modules' --exclude='.git' --exclude='*.tar.gz' -czvf raqib-docker.tar.gz ."
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "concurrently": "^8.2.2"
  }
}
